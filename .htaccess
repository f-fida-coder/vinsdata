RewriteEngine On
Options -Indexes

# Route /api/* requests to the corresponding PHP file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/(.+)$ api/$1.php [L,QSA]

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback: all other routes serve index.html
RewriteRule ^ index.html [L]

# Caching policy. Vite emits content-hashed asset filenames
# (index-XYZ.js, index-ABC.css) so those can cache forever and the
# browser picks up the new bundle automatically when the hash changes.
# The HTML shell + service worker MUST NOT cache or operators won't
# see new deploys without a hard refresh.
<IfModule mod_headers.c>
  # index.html / any HTML route: never cached, always revalidate.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  # Hashed JS/CSS/font assets — safe to cache for 1 year, immutable.
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
