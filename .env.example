# Copy to .env (gitignored) and fill in. config.php reads this at startup.
#
# Two locations are searched, first hit wins:
#   1. <domain root>/.env  on production (e.g. /home/.../crm.vinvault.us/.env)
#   2. <repo root>/.env    on local dev (this file's location)
#
# Never commit a .env file with real values.

DB_HOST=srv2052.hstgr.io
DB_NAME=u487877829_vins_data
DB_USER=u487877829_vinsdata
DB_PASS=replace-me

# -----------------------------------------------------------------------------
# Outbound providers. All optional — leave blank to keep the stub adapter
# (marks every send sent without actually leaving the box). See
# api/outbound_helpers.php for adapter behavior.
# -----------------------------------------------------------------------------

# Gmail / Workspace SMTP — generate at myaccount.google.com/apppasswords.
# Requires 2FA on the sending account. The password is the 16-char
# "App password" string (with or without spaces — strip them).
GMAIL_SMTP_USER=
GMAIL_SMTP_PASS=
GMAIL_FROM_EMAIL=   # optional override, defaults to GMAIL_SMTP_USER
GMAIL_FROM_NAME=    # optional, e.g. "Vin Vault"

# OpenPhone — API key from Settings → API. The phone-number-id is the
# PN... segment in the URL of one of your owned numbers. The webhook
# secret is shown ONCE when you create a webhook subscription.
OPENPHONE_API_KEY=
OPENPHONE_PHONE_NUMBER_ID=
OPENPHONE_WEBHOOK_SECRET=

# Email signature block (used by Gmail-sent messages). Defaults baked
# into outbound_helpers.php so these are only needed if you want to
# override.
SIGNATURE_BRAND_URL=     # default: https://vinvault.us
SIGNATURE_LOGO_URL=      # default: https://crm.vinvault.us/brand/vinvault-logo.svg
SIGNATURE_CONTACT_EMAIL= # default: admin@vinvault.us
SIGNATURE_CONTACT_PHONE= # default: (469) 971-2609
